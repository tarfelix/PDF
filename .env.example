CORS_ORIGINS=*
TEMP_FILE_TTL_MINUTES=30
MAX_UPLOAD_SIZE_MB=200

# --- SSO central (oauth2-proxy / M365) ---
# Em producao o edge (Traefik forwardauth) injeta os headers X-Auth-Request-*.
ENVIRONMENT=production
# DEV_BYPASS_AUTH=1 so para rodar local sem oauth2-proxy (proibido em producao).
DEV_BYPASS_AUTH=
# Override de papel por email: "email1=admin,email2=socio+gestora"
SSO_EMAIL_ROLE_MAP=

# Anti-spoof do header SSO (WP-SEC2) — ver backend/auth.py.
# Quando setado, exige que o Traefik tenha injetado X-Proxy-Secret
# (customRequestHeaders via @file) antes de confiar em X-Auth-Request-Email.
# Runtime-only: setar via Coolify Environment Variables (NÃO no .env de build,
# NÃO no docker-compose.yaml versionado). Vazio = comportamento antigo (sem proxy).
# PROXY_SHARED_SECRET=
